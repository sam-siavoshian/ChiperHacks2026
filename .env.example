# Copy to .env and fill. Never commit .env.

# --- model for Red brains + Blue mapper ---
# Pick ONE provider. Red uses the OpenAI Agents SDK; if ANTHROPIC_API_KEY is set
# the swarm routes through LiteLLM to Claude, else it uses OpenAI directly.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# model ids (override defaults if you want)
RED_MODEL=claude-sonnet-4-6
BLUE_MODEL=claude-sonnet-4-6

# --- topology (defaults match docker/ + scripts/) ---
ARENA_BUS=http://127.0.0.1:8765
ARENA_TARGET=http://127.0.0.1:3000        # juice shop (direct)
ARENA_TARGET_SPARE=http://127.0.0.1:3001  # hot-spare
ARENA_WAF=http://127.0.0.1:8080           # red points here (through Blue)
ARENA_WAF_CONTROL=http://127.0.0.1:9090   # blue rule control plane

# safety: keep everything on localhost. The target is deliberately vulnerable.
ARENA_BIND=127.0.0.1
